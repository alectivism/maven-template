# MMA MAVEN Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env

# ============================================
# CORE INTEGRATIONS
# ============================================

# Microsoft 365 (Outlook, Calendar, OneDrive, SharePoint)
# Uses device flow auth, no keys needed here

# Slack
# Uses OAuth token from setup script
SLACK_BOT_TOKEN=

# Asana (Personal Access Token)
# Get from: https://app.asana.com/0/developer-console
ASANA_ACCESS_TOKEN=

# Parallel Search (web search)
# Get from: https://platform.parallel.ai
PARALLEL_SEARCH_API_KEY=

# ============================================
# OPTIONAL INTEGRATIONS
# ============================================

# Salesforce
# Uses OAuth, no keys needed here

# Fireflies (meeting transcription)
# Get from: https://app.fireflies.ai/integrations/custom/fireflies
FIREFLIES_API_KEY=

# OpenAI
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Gemini
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Zapier
# Uses OAuth, no keys needed here

# ============================================
# CUSTOM
# ============================================

# Add your own keys here as needed
# MY_SERVICE_API_KEY=
